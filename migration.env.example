# Environment variables for data migration
# Copy this file to .env and fill in your actual database URLs

# Supabase Database (Source - Read Only)
# Format: postgresql://username:password@host:port/database
# Example: postgresql://postgres.abcdefghijk:password@aws-0-us-east-1.pooler.supabase.com:5432/postgres
SUPABASE_DATABASE_URL=postgresql://your_supabase_user:your_password@your_supabase_host:5432/postgres

# Railway Database (Target - Write Access)  
# Get this from your Railway project dashboard -> Database -> Connect
# Format: postgresql://username:password@host:port/database
# Example: postgresql://postgres:password@roundhouse.proxy.rlwy.net:12345/railway
RAILWAY_DATABASE_URL=postgresql://your_railway_user:your_password@your_railway_host:port/railway


