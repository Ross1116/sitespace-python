# Environment variables for API-based data migration
# Copy this file to .env and fill in your actual values

# Supabase API Configuration (No database password needed!)
# Get these from your Supabase dashboard -> Settings -> API
# Project URL: https://your-project-id.supabase.co
SUPABASE_URL=https://your-project-id.supabase.co

# Anon Key: Found in Settings -> API -> Project API keys -> anon/public
# This is safe to use - it's designed for client-side access
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-anon-key-here

# Railway Database (Target - Write Access)  
# Get this from your Railway project dashboard -> Database -> Connect
# Format: postgresql://username:password@host:port/database
RAILWAY_DATABASE_URL=postgresql://postgres:your_password@your_railway_host:port/railway





