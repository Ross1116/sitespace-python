# Database Configuration
DATABASE_URL=postgresql://<db_user>:<db_password>@<db_host>:5432/<db_name>

# JWT Configuration
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
JWT_ALGORITHM=HS512
JWT_EXPIRATION_MS=86400000

# App Configuration
SECRET_KEY=CHANGE_ME_TO_A_DIFFERENT_LONG_RANDOM_SECRET
EXPORT_FILES_ABSOLUTE_PATH=D:/New_folder/
EXPORT_FILES_SERVER_PATH=getFile

# Server Configuration
HOST=0.0.0.0
PORT=8080
DEBUG=False

# CORS Configuration - Comma-separated list of allowed origins
CORS_ORIGINS=https://sitespace.vercel.app, http://sitespace.com.au, https://sitespace.com.au,http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000

# Sentry Configuration
SENTRY_DSN=