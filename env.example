# Database Configuration
DATABASE_URL=postgresql://<db_user>:<db_password>@<db_host>:5432/<db_name>
DB_CONNECT_TIMEOUT=10

# JWT Configuration
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
JWT_ALGORITHM=HS512
JWT_EXPIRATION_MS=86400000

# App Configuration
SECRET_KEY=CHANGE_ME_TO_A_DIFFERENT_LONG_RANDOM_SECRET
EXPORT_FILES_ABSOLUTE_PATH=D:/New_folder/
EXPORT_FILES_SERVER_PATH=getFile

# Server Configuration
HOST=0.0.0.0
PORT=8080
DEBUG=False

# CORS Configuration - Comma-separated list of allowed origins
CORS_ORIGINS=https://sitespace.vercel.app, http://sitespace.com.au, https://sitespace.com.au,http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000

# Sentry Configuration
SENTRY_DSN=

# AI Provider and Model
AI_ENABLED=true
AI_PROVIDER=anthropic
AI_API_KEY=sk-ant-<your-key-here>
AI_MODEL=claude-haiku-4-5-20251001
# For OpenAI: AI_PROVIDER=openai, AI_API_KEY=sk-..., AI_MODEL=gpt-4o (or gpt-5 when available)

# AI Timeouts and Budget
AI_TIMEOUT_STRUCTURE=20
AI_TIMEOUT_CLASSIFY=30
AI_TIMEOUT_WORK_PROFILE=25
AI_UPLOAD_COST_BUDGET_USD=5.0
# Optional: set active-model pricing so upload/work-profile AI cost is persisted.
# Values are USD per 1M input/output tokens for the configured AI_MODEL.
AI_INPUT_COST_PER_MILLION_USD=
AI_OUTPUT_COST_PER_MILLION_USD=

# Nightly Lookahead Scheduler
NIGHTLY_LOOKAHEAD_HOUR=18
NIGHTLY_LOOKAHEAD_MINUTE=30
NIGHTLY_LOOKAHEAD_TIMEZONE=Australia/Adelaide
